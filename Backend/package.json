{
  "name": "boxed-bliss-backend",
  "version": "1.0.0",
  "description": "Boxed Bliss — REST API backend with Express, Prisma, MongoDB, and Cloudinary",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate --config prisma.config.ts && tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:push": "prisma db push --config prisma.config.ts"
  },
  "dependencies": {
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jose": "^5.9.6",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.17.10",
    "prisma": "^7.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
